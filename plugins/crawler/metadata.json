{
  "id": "crawler",
  "name": "Crawler",
  "version": "1.0.0",
  "description": "Depth-limited Katana crawl for recursive link discovery.",
  "long_description": "Runs Katana with a configurable crawl depth to recursively discover links from a target URL. Use this for general active crawling where depth control matters.",
  "category": "robots",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "engine": {
    "type": "cli",
    "binary": "katana"
  },
  "command_template": [
    "katana",
    "-u",
    "{target}",
    "-depth",
    "{depth:2}",
    "-silent"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Target URL",
      "type": "string",
      "required": true,
      "placeholder": "https://secuscan.in",
      "validation": {
        "validation_type": "url",
        "message": "Must be a valid HTTP or HTTPS URL"
      }
    },
    {
      "id": "depth",
      "label": "Depth",
      "type": "integer",
      "required": false,
      "default": 2
    }
  ],
  "presets": {
    "default": {
      "depth": 2
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "Crawler sends active traffic and requires authorization.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "katana"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "capabilities": [
    "network",
    "intrusive"
  ],
  "checksum": "2e3d4dbcdcede18f25d4a6ed5724a0afccba6fb7c4e51ea39fbf9ba7a569b97a"
}
