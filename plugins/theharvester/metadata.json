{
  "id": "theharvester",
  "name": "theHarvester",
  "version": "1.0.0",
  "description": "OSINT collection for emails, domains, and hosts.",
  "long_description": "OSINT collection for emails, domains, and hosts.",
  "category": "recon",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🔎",
  "engine": {
    "type": "cli",
    "binary": "theHarvester"
  },
  "command_template": [
    "theHarvester",
    "-d",
    "{target}",
    "-b",
    "all"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Target Domain",
      "type": "string",
      "required": true,
      "placeholder": "secuscan.in"
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": false,
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "theHarvester"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "capabilities": [
    "network"
  ],
  "checksum": "c6c1335f1315786e60d57d6a8295a70016822a09dbeab55915e13dbb6fd3fba2"
}
